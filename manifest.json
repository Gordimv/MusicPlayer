{
  "manifest_version": 3,
  "name": "Music Deck",
  "version": "0.3.0",
  "description": "A lightweight Firefox controller for YouTube Music.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://music.youtube.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "Music Deck",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "music-deck@gordimv.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}